APP_ENV=local
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
DATABASE_URL=postgres://atlas_auth:atlas_auth@localhost:5432/atlas_auth
JWT_ISSUER=atlas-auth
JWT_AUDIENCE=atlas-services
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000
JWT_SIGNING_KEY_ID=local-dev-key
JWT_PRIVATE_KEY_PEM=replace-with-rs256-private-key-pem-from-secret-manager
JWT_PUBLIC_KEY_PEM=replace-with-rs256-public-key-pem
PASSWORD_PEPPER=replace-with-secret-manager-value
